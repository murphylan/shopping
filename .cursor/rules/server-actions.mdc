# Server Actions 规范

**位置**: `server/actions/{entity}Action.ts`

## 必须遵守

- 文件顶部: `"use server";`
- 导入: `import "server-only";`
- 权限检查: `const user = await getCurrentUser();`
- 返回格式: `{ success: boolean, data?: T, error?: string }`
- 错误处理: try-catch 包裹所有操作
- 缓存刷新: `revalidatePath()`

## 模板

```typescript
"use server";

import { getCurrentUser } from "@/server/auth/require-auth";
import { db } from "@/server/db";
import { entities } from "@/server/db/schema";
import { eq, desc } from "drizzle-orm";
import { revalidatePath } from "next/cache";
import "server-only";
import { entitySchema, type EntityFormData } from "@/types/entity-types";
import { randomUUID } from "crypto";

export async function createEntity(data: EntityFormData) {
  const user = await getCurrentUser();
  if (!user) {
    return { success: false, error: "未登录" };
  }

  try {
    const validated = entitySchema.parse(data);
    const [entity] = await db
      .insert(entities)
      .values({
        id: randomUUID(),
        businessId: await generateEntityId(),
        title: validated.title,
        createdBy: user.id,
        updatedBy: user.id,
        createdAt: new Date(),
        updatedAt: new Date(),
      })
      .returning();

    revalidatePath("/entities");
    return { success: true, data: entity };
  } catch (error) {
    console.error("Failed to create entity:", error);
    return {
      success: false,
      error: error instanceof Error ? error.message : "创建失败",
    };
  }
}
```

## 命名约定

| 操作 | 命名格式 |
|------|----------|
| 创建 | `createXxx` |
| 获取单个 | `getXxxByBusinessId` |
| 获取列表 | `listXxx` |
| 更新 | `updateXxxByBusinessId` |
| 删除 | `deleteXxxByBusinessId` |

## 禁止事项

- ❌ 返回格式不是 `{ success, data, error }`
- ❌ 不使用 try-catch
- ❌ 不检查用户登录状态
- ❌ 使用 Prisma（项目使用 Drizzle ORM）
