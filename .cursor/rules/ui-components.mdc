# React 组件与 UI 模式规范

> 基础样式规范（8px 网格、字体层级、颜色等）请参考 `ui-style.mdc`

---

## 第一部分：React 组件规范

### 页面组件规范

#### 必须遵守

- 使用 `useTopLoader` 的 `start()`/`done()` 显示加载状态
- 使用 `toast` from `sonner` 提示结果
- 使用 `mutation.isPending`（不是 `isLoading`）
- 使用 try-finally 包裹异步操作
- **禁止** 将 `start`/`done` 添加到 `useCallback` 依赖（会导致死循环）

#### 模板

```tsx
"use client";

import { useCallback, useTransition } from "react";
import { useRouter } from "next/navigation";
import { useTopLoader } from "nextjs-toploader";
import { toast } from "sonner";
import { useEntities } from "@/hooks/use-entities";
import type { EntityFormData } from "@/types/entity-types";

export default function CreateEntityPage() {
  const router = useRouter();
  const [isPending, startTransition] = useTransition();
  const { start, done } = useTopLoader();
  const { createEntityMutation } = useEntities();

  const handleCreate = useCallback(
    async (values: EntityFormData) => {
      start();
      try {
        const res = await createEntityMutation.mutateAsync(values);
        if (res.success) {
          toast.success("创建成功");
          router.push("/entities");
        } else {
          toast.error(res.error || "创建失败");
        }
      } finally {
        done();
      }
    },
    [createEntityMutation, router] // ⚠️ 不添加 start/done
  );

  return (
    <EntityForm
      onSubmit={handleCreate}
      submitting={createEntityMutation.isPending}
    />
  );
}
```

### 删除功能规范

必须使用 `DeleteConfirm` 组件，禁止 `window.confirm`：

```tsx
import { DeleteConfirm } from "@/components/DeleteConfirm";
import { useTopLoader } from "nextjs-toploader";
import { toast } from "sonner";

function EntityRow({ entity }: { entity: Entity }) {
  const { deleteEntityMutation } = useEntities();
  const { start, done } = useTopLoader();

  const handleDelete = useCallback(async () => {
    start();
    try {
      const res = await deleteEntityMutation.mutateAsync(entity.businessId);
      if (res.success) toast.success("已删除");
      else toast.error(res.error || "删除失败");
    } finally {
      done();
    }
  }, [entity.businessId, deleteEntityMutation]);

  return (
    <DeleteConfirm
      entityName={entity.title}
      isLoading={deleteEntityMutation.isPending}
      onConfirm={handleDelete}
    />
  );
}
```

### 表单组件规范

使用 React Hook Form + Zod：

```tsx
import { useForm } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { entitySchema, type EntityFormData } from "@/types/entity-types";
import { Form, FormControl, FormField, FormItem, FormLabel, FormMessage } from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";

interface EntityFormProps {
  defaultValues?: Partial<EntityFormData>;
  onSubmit: (data: EntityFormData) => Promise<void>;
  submitting?: boolean;
}

export function EntityForm({ defaultValues, onSubmit, submitting }: EntityFormProps) {
  const form = useForm<EntityFormData>({
    resolver: zodResolver(entitySchema),
    defaultValues: defaultValues || { title: "", description: "" },
  });

  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-4">
        <FormField
          control={form.control}
          name="title"
          render={({ field }) => (
            <FormItem>
              <FormLabel>标题</FormLabel>
              <FormControl><Input {...field} /></FormControl>
              <FormMessage />
            </FormItem>
          )}
        />
        <Button type="submit" disabled={submitting}>
          {submitting ? "保存中..." : "保存"}
        </Button>
      </form>
    </Form>
  );
}
```

